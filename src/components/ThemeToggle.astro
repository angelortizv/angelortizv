<button type="button" class="theme-toggle" id="theme-toggle" aria-label="Cambiar tema">
  <span class="theme-toggle-icon theme-toggle-icon--dark" aria-hidden="true">☀</span>
  <span class="theme-toggle-icon theme-toggle-icon--light" aria-hidden="true">☾</span>
</button>

<script>
  function getThemeColor(theme: string) {
    return theme === 'light' ? '#fafafa' : '#0a0a0a';
  }

  function setThemeMeta(theme: string) {
    const meta = document.getElementById('theme-color-meta');
    if (meta) meta.setAttribute('content', getThemeColor(theme));
  }

  function applyTheme(theme: string) {
    document.documentElement.dataset.theme = theme;
    localStorage.setItem('theme', theme);
    setThemeMeta(theme);

    const btn = document.getElementById('theme-toggle');
    btn?.setAttribute('aria-label', theme === 'light' ? 'Activar modo oscuro' : 'Activar modo claro');
  }

  function initThemeToggle() {
    const btn = document.getElementById('theme-toggle');
    if (!btn || btn.dataset.ready) return;
    btn.dataset.ready = 'true';

    const current = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
    setThemeMeta(current);
    btn.setAttribute('aria-label', current === 'light' ? 'Activar modo oscuro' : 'Activar modo claro');

    btn.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
      applyTheme(next);
    });
  }

  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>
