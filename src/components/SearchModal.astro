<div id="search-modal" class="search-modal" role="dialog" aria-modal="true" aria-label="Buscar" hidden>
  <div class="search-modal-backdrop" data-search-close tabindex="-1"></div>
  <div class="search-modal-panel">
    <div class="search-modal-header">
      <span class="search-modal-title">Buscar</span>
      <kbd class="search-kbd">Esc</kbd>
    </div>
    <div id="search-modal-ui"></div>
  </div>
</div>

<script>
  let pagefindReady = false;
  let pagefindCssLoaded = false;
  let lastTrigger: HTMLElement | null = null;

  const FOCUSABLE =
    'a[href], button:not([disabled]), input:not([disabled]), textarea, select, [tabindex]:not([tabindex="-1"])';

  function getModal() {
    return document.getElementById('search-modal');
  }

  function getSiteWrapper() {
    return document.querySelector<HTMLElement>('.site-wrapper');
  }

  function getFocusableElements(container: HTMLElement) {
    return [...container.querySelectorAll<HTMLElement>(FOCUSABLE)].filter(
      el => !el.closest('[hidden]') && el.offsetParent !== null,
    );
  }

  function handleTabTrap(e: KeyboardEvent) {
    const modal = getModal();
    if (!modal || modal.hidden || e.key !== 'Tab') return;

    const panel = modal.querySelector<HTMLElement>('.search-modal-panel');
    if (!panel) return;

    const focusables = getFocusableElements(panel);
    if (focusables.length === 0) return;

    const first = focusables[0];
    const last = focusables[focusables.length - 1];

    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function loadPagefindCss() {
    if (pagefindCssLoaded) return;
    if (document.querySelector('link[data-pagefind-css]')) {
      pagefindCssLoaded = true;
      return;
    }

    const link = document.createElement('link');
    link.rel = 'stylesheet';
    link.href = '/pagefind/pagefind-ui.css';
    link.setAttribute('data-pagefind-css', '');
    document.head.appendChild(link);
    pagefindCssLoaded = true;
  }

  async function loadPagefind() {
    if (pagefindReady) return;

    loadPagefindCss();

    await new Promise<void>((resolve, reject) => {
      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.onload = () => resolve();
      script.onerror = () => reject(new Error('Pagefind no disponible'));
      document.head.appendChild(script);
    });

    // @ts-expect-error PagefindUI is injected by pagefind-ui.js
    new PagefindUI({
      element: '#search-modal-ui',
      showSubResults: false,
      resetStyles: true,
      translations: {
        placeholder: 'Buscar posts...',
        zero_results: 'No se encontraron resultados para [SEARCH_TERM].',
      },
    });

    pagefindReady = true;
  }

  async function openSearch(trigger?: HTMLElement) {
    const modal = getModal();
    if (!modal) return;

    lastTrigger = trigger ?? (document.activeElement as HTMLElement | null);

    try {
      await loadPagefind();
    } catch {
      window.location.href = '/buscar';
      return;
    }

    modal.hidden = false;
    document.body.classList.add('search-open');
    getSiteWrapper()?.setAttribute('inert', '');

    document.addEventListener('keydown', handleTabTrap);

    const input = modal.querySelector<HTMLInputElement>('input');
    input?.focus();
  }

  function closeSearch() {
    const modal = getModal();
    if (!modal) return;

    modal.hidden = true;
    document.body.classList.remove('search-open');
    getSiteWrapper()?.removeAttribute('inert');
    document.removeEventListener('keydown', handleTabTrap);

    lastTrigger?.focus();
    lastTrigger = null;
  }

  function initSearchModal() {
    if (document.body.dataset.searchInit) return;
    document.body.dataset.searchInit = 'true';

    document.querySelectorAll('[data-search-open]').forEach(trigger => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        openSearch(e.currentTarget as HTMLElement);
      });
    });

    getModal()?.querySelectorAll('[data-search-close]').forEach(el => {
      el.addEventListener('click', closeSearch);
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        const modal = getModal();
        if (modal?.hidden) {
          const trigger = document.querySelector<HTMLElement>('[data-search-open]');
          openSearch(trigger ?? undefined);
        } else {
          closeSearch();
        }
        return;
      }

      if (e.key === 'Escape' && !getModal()?.hidden) {
        closeSearch();
      }
    });
  }

  initSearchModal();
  document.addEventListener('astro:page-load', initSearchModal);
</script>
