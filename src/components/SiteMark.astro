---
interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<svg
  class:list={['site-mark', className]}
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 32 32"
  width="28"
  height="28"
  aria-hidden="true"
>
  <rect x="7" y="7" width="18" height="2.5" rx="1" fill="var(--accent)" />
  <path
    d="M9 24 L16 11 L23 24"
    fill="none"
    stroke="var(--text)"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
  <line
    x1="11.5"
    y1="19.5"
    x2="20.5"
    y2="19.5"
    stroke="var(--accent)"
    stroke-width="2"
    stroke-linecap="round"
  />
</svg>
