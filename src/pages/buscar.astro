---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Buscar — Angelo Ortiz" description="Busca en todos los posts del blog.">
  <div class="page-header">
    <h1>Buscar</h1>
    <p>Usa <kbd class="search-kbd">⌘K</kbd> desde cualquier página para abrir la búsqueda.</p>
  </div>

  <p class="text-muted">
    <button type="button" class="link-accent link-btn" data-search-open>Abrir búsqueda</button>
  </p>
</BaseLayout>
