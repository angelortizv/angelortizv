---
import { getCollection } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import PostNav from '../../components/PostNav.astro';
import { formatDate } from '../../utils/formatDate';
import { extractHeadings } from '../../utils/extractHeadings';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts: posts },
  }));
}

const { post, allPosts } = Astro.props;
const { Content } = await post.render();

const words = post.body.split(/\s+/).filter(Boolean).length;
const readingTime = Math.max(1, Math.round(words / 200));
const headings = extractHeadings(post.body);

const sorted = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const currentIndex = sorted.findIndex(p => p.slug === post.slug);
const older = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const newer = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const related = allPosts
  .filter(p => p.slug !== post.slug && p.data.tags.some(t => post.data.tags.includes(t)))
  .sort((a, b) => {
    const sharedA = a.data.tags.filter(t => post.data.tags.includes(t)).length;
    const sharedB = b.data.tags.filter(t => post.data.tags.includes(t)).length;
    return sharedB - sharedA || b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 3);
---

<PostLayout
  title={post.data.title}
  date={post.data.date}
  description={post.data.description}
  tags={post.data.tags}
  slug={post.slug}
  readingTime={readingTime}
  headings={headings}
>
  <Content />

  {readingTime >= 4 && (
    <div class="back-to-top">
      <a href="#top">↑ Volver arriba</a>
    </div>
  )}

  <PostNav
    older={older ? { slug: older.slug, title: older.data.title } : null}
    newer={newer ? { slug: newer.slug, title: newer.data.title } : null}
  />

  {related.length > 0 && (
    <aside class="related-posts">
      <p class="home-section-title">También puede interesarte</p>
      <ul class="post-list">
        {related.map(p => (
          <li class="post-item">
            <time class="post-date" datetime={p.data.date.toISOString()}>
              {formatDate(p.data.date)}
            </time>
            <a class="post-title-link" href={`/writing/${p.slug}`}>
              {p.data.title}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )}
</PostLayout>
