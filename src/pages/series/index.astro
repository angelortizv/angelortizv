---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { SERIES_META } from '../../data/series';
import { getActiveSeries, getSeriesPosts } from '../../utils/series';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const seriesSlugs = getActiveSeries(allPosts);
---

<BaseLayout title="Series — Angelo Ortiz" description="Colecciones de posts agrupados por tema.">
  <div class="page-header">
    <h1>Series</h1>
    <p>Posts que forman parte de un mismo hilo o proyecto.</p>
  </div>

  <ul class="series-index">
    {seriesSlugs.map(slug => {
      const posts = getSeriesPosts(allPosts, slug);
      const meta = SERIES_META[slug];
      return (
        <li>
          <a href={`/series/${slug}`} class="series-index-item">
            <span class="series-index-title">{meta.title}</span>
            <span class="series-index-count">
              {posts.length} {posts.length === 1 ? 'parte' : 'partes'}
            </span>
          </a>
          <p class="series-index-desc">{meta.description}</p>
        </li>
      );
    })}
  </ul>
</BaseLayout>
