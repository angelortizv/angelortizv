---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';
import { formatMonthYear } from '../utils/formatDate';

const entry = await getEntry('now', 'index');
if (!entry) throw new Error('Falta src/content/now/index.md');

const { Content } = await entry.render();
const updatedLabel = formatMonthYear(entry.data.updated);
---

<BaseLayout
  title="Ahora — Angelo Ortiz"
  description="Qué estoy haciendo ahora mismo."
>
  <div class="page-header">
    <h1>Ahora</h1>
    <p class="now-updated">Actualizado {updatedLabel}</p>
  </div>

  <div class="now-content prose">
    <Content />
  </div>

  <p class="now-footer">
    <a href="/about">Acerca de</a>
  </p>
</BaseLayout>
