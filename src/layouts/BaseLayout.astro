---
import '../styles/global.css';
import SearchModal from '../components/SearchModal.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

const DEFAULT_DESCRIPTION =
  'Angelo Ortiz Vega — escritura sobre tecnología, ideas y cosas que vale la pena recordar.';

interface Props {
  title: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogUrl?: string;
  ogImage?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  ogType = 'website',
  ogUrl,
  ogImage,
  publishedTime,
  jsonLd,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = ogUrl ?? new URL(currentPath, Astro.site).href;
const ogImageUrl = ogImage
  ? new URL(ogImage, Astro.site).href
  : new URL('/og/default', Astro.site).href;
const siteName = 'Angelo Ortiz Vega';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <title>{title}</title>

    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fafafa" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" id="theme-color-meta" content="#0a0a0a" />

    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
        const theme = stored ?? (prefersLight ? 'light' : 'dark');
        document.documentElement.dataset.theme = theme;
        const meta = document.getElementById('theme-color-meta');
        if (meta) meta.setAttribute('content', theme === 'light' ? '#fafafa' : '#0a0a0a');
      })();
    </script>

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={siteName} href="/rss.xml" />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body id="top">
    <a href="#main-content" class="skip-link">Saltar al contenido</a>

    <div class="site-wrapper">
      <header>
        <div class="inner">
          <a href="/" class="site-name">Angelo</a>
          <nav aria-label="Navegación principal">
            <a href="/writing" aria-current={currentPath.startsWith('/writing') ? 'page' : undefined}>Escritura</a>
            <a href="/tags" aria-current={currentPath.startsWith('/tags') ? 'page' : undefined}>Categorías</a>
            <button type="button" class="nav-search-btn" data-search-open aria-label="Buscar (Ctrl+K)">
              Buscar
              <kbd class="nav-kbd">⌘K</kbd>
            </button>
            <a href="/about" aria-current={currentPath === '/about' ? 'page' : undefined}>Acerca de</a>
          </nav>
        </div>
      </header>

      <main id="main-content">
        <slot />
      </main>

      <footer>
        <p>© {new Date().getFullYear()} Angelo Ortiz Vega</p>
        <div class="footer-links">
          <ThemeToggle />
          <a href="https://www.angelortizv.me" target="_blank" rel="noopener">angelortizv.me</a>
          <a href="/now">Ahora</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </footer>
    </div>

    <SearchModal />
  </body>
</html>
